generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------
// Core Models for "Collective Unconscious"
//
// Refined schema focusing on anonymous, low-pressure writing loops.
// -----------------------------------------------------------------

model Log {
  id                 String   @id @default(uuid())
  title              String
  category           String   @default("Freewriting")

  // Modes
  accessMode         String   @default("OPEN")      // "OPEN" | "PRIVATE"
  turnMode           String   @default("FREESTYLE") // "FREESTYLE" | "STRUCTURED"
  
  // Advanced Settings
  participantLimit   Int?     // null means unlimited
  roundLimit         Int?     // null means unlimited
  turnTimeout        Int?     // Timeout in seconds (null = none)
  perTurnLengthLimit Int?     // Characters per turn (null = none)
  seed               String?  // Initial prompt or constraint

  // State
  status             String   @default("ACTIVE")    // "ACTIVE" | "COMPLETED"
  accessCode         String?  // Shareable code for private logs (e.g., 6-chars)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  writers            Writer[]
  turns              Turn[]
}

model Writer {
  id           String   @id @default(uuid())
  sessionToken String   // Link to an anonymous session
  
  nickname     String?  // E.g., "Musing Crow"
  colorHex     String   // E.g., "#FF8C00"
  
  logId        String
  log          Log      @relation(fields: [logId], references: [id], onDelete: Cascade)
  
  joinOrder    Int      // 1 for creator (keeper), 2 for second participant...

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  turns        Turn[]

  @@unique([sessionToken, logId])
}

model Turn {
  id           String   @id @default(uuid())
  content      String   @db.Text
  turnOrder    Int      // Sequence number within the Log (1, 2, 3...)

  logId        String
  log          Log      @relation(fields: [logId], references: [id], onDelete: Cascade)

  writerId     String
  writer       Writer   @relation(fields: [writerId], references: [id], onDelete: Cascade)

  isSkip       Boolean  @default(false)
  isEntrance   Boolean  @default(false)

  createdAt    DateTime @default(now())

  @@unique([logId, turnOrder])
}
