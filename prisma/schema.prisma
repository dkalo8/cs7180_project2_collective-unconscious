generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------
// Core Models for "Collective Unconscious"
//
// Refined schema focusing on anonymous, low-pressure writing loops.
// -----------------------------------------------------------------

model Log {
  id                 String   @id @default(uuid())
  title              String
  category           Category @default(FREEWRITING)

  // Modes
  accessMode         AccessMode @default(OPEN)
  turnMode           TurnMode   @default(FREESTYLE)
  
  // Advanced Settings
  participantLimit   Int?     // null means unlimited
  turnLimit          Int?     @map("roundLimit") // total submitted turns before auto-close; null means unlimited
  turnTimeout        Int?     // Timeout in seconds (null = none)
  perTurnLengthLimit Int?     // Characters per turn (null = none)
  seed               String?  // Initial prompt or constraint

  // State
  status             LogStatus @default(ACTIVE)
  accessCode         String?  // Shareable code for private logs (e.g., 6-chars)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  creatorToken       String?  // Session token of the log creator / keeper

  writers            Writer[]
  turns              Turn[]
  reactions          Reaction[]
}

model User {
  id          String   @id @default(uuid())
  googleId    String   @unique
  email       String   @unique
  displayName String
  bio         String?
  avatarUrl   String?
  role        UserRole @default(USER)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  writers      Writer[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Writer {
  id           String   @id @default(uuid())
  sessionToken String

  nickname     String?
  colorHex     String

  logId        String
  log          Log      @relation(fields: [logId], references: [id], onDelete: Cascade)

  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  joinOrder    Int

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  turns        Turn[]

  @@unique([sessionToken, logId])
}

model Turn {
  id           String   @id @default(uuid())
  content      String   @db.Text
  turnOrder    Int

  logId        String
  log          Log      @relation(fields: [logId], references: [id], onDelete: Cascade)

  writerId     String
  writer       Writer   @relation(fields: [writerId], references: [id], onDelete: Cascade)

  isSkip            Boolean  @default(false)
  isOutOfRotation   Boolean  @default(false) @map("isEntrance")
  isHidden          Boolean  @default(false)

  createdAt    DateTime @default(now())

  @@unique([logId, turnOrder])
}

model Report {
  id            String   @id @default(uuid())
  reporterToken String   // Session token of the reporter
  reason        String
  targetType    TargetType
  targetId      String
  status        ReportStatus @default(PENDING)
  
  createdAt     DateTime @default(now())
  
  actions       ModerationAction[]
}

model Reaction {
  id           String   @id @default(uuid())
  sessionToken String
  symbol       String   // one of: ✦ ◎ ∿ ⌖
  logId        String
  log          Log      @relation(fields: [logId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())

  @@unique([sessionToken, logId, symbol])
}

model ModerationAction {
  id            String   @id @default(uuid())
  moderatorId   String   // User ID of the moderator
  action        ModAction
  reportId      String
  report        Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  targetId      String
  note          String?
  
  createdAt     DateTime @default(now())
}

enum AccessMode {
  OPEN
  PRIVATE
}

enum TurnMode {
  FREESTYLE
  STRUCTURED
}

enum LogStatus {
  ACTIVE
  COMPLETED
}

enum Category {
  FREEWRITING
  HAIKU
  POEM
  SHORT_NOVEL
}

enum UserRole {
  USER
  ADMIN
}

enum TargetType {
  TURN
  LOG
}

enum ReportStatus {
  PENDING
  DISMISSED
  ACTIONED
}

enum ModAction {
  HIDE_TURN
  CLOSE_LOG
  DISMISS
}
