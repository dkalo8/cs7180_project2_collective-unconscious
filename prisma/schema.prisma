generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------
// Core Models for "Collective Unconscious"
//
// Refined schema focusing on anonymous, low-pressure writing loops.
// -----------------------------------------------------------------

model Log {
  id                 String   @id @default(uuid())
  title              String
  category           String   @default("Freewriting")

  // Modes
  accessMode         String   @default("OPEN")      // "OPEN" | "PRIVATE"
  turnMode           String   @default("FREESTYLE") // "FREESTYLE" | "STRUCTURED"
  
  // Advanced Settings
  participantLimit   Int?     // null means unlimited
  turnLimit          Int?     @map("roundLimit") // total submitted turns before auto-close; null means unlimited
  turnTimeout        Int?     // Timeout in seconds (null = none)
  perTurnLengthLimit Int?     // Characters per turn (null = none)
  seed               String?  // Initial prompt or constraint

  // State
  status             String   @default("ACTIVE")    // "ACTIVE" | "COMPLETED"
  accessCode         String?  // Shareable code for private logs (e.g., 6-chars)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  creatorToken       String?  // Session token of the log creator / keeper

  writers            Writer[]
  turns              Turn[]
}

model User {
  id          String   @id @default(uuid())
  googleId    String   @unique
  email       String   @unique
  displayName String
  bio         String?
  avatarUrl   String?
  role        String   @default("USER") // "USER" | "ADMIN"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  writers      Writer[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Writer {
  id           String   @id @default(uuid())
  sessionToken String

  nickname     String?
  colorHex     String

  logId        String
  log          Log      @relation(fields: [logId], references: [id], onDelete: Cascade)

  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  joinOrder    Int

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  turns        Turn[]

  @@unique([sessionToken, logId])
}

model Turn {
  id           String   @id @default(uuid())
  content      String   @db.Text
  turnOrder    Int

  logId        String
  log          Log      @relation(fields: [logId], references: [id], onDelete: Cascade)

  writerId     String
  writer       Writer   @relation(fields: [writerId], references: [id], onDelete: Cascade)

  isSkip            Boolean  @default(false)
  isOutOfRotation   Boolean  @default(false) @map("isEntrance")
  isHidden          Boolean  @default(false)

  createdAt    DateTime @default(now())

  @@unique([logId, turnOrder])
}

model Report {
  id            String   @id @default(uuid())
  reporterToken String   // Session token of the reporter
  reason        String
  targetType    String   // "TURN" | "LOG"
  targetId      String
  status        String   @default("PENDING") // "PENDING" | "DISMISSED" | "ACTIONED"
  
  createdAt     DateTime @default(now())
  
  actions       ModerationAction[]
}

model ModerationAction {
  id            String   @id @default(uuid())
  moderatorId   String   // User ID of the moderator
  action        String   // "HIDE_TURN" | "CLOSE_LOG" | "DISMISS"
  reportId      String
  report        Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  targetId      String
  note          String?
  
  createdAt     DateTime @default(now())
}
